# Environment variables for FoodFrenzy

# Server port (Railway usually provides this automatically via PORT)
PORT=8080

# Database Configuration (PostgreSQL)
# Format: jdbc:postgresql://<host>:<port>/<database>
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/foodfrenzy
SPRING_DATASOURCE_USERNAME=postgres
SPRING_DATASOURCE_PASSWORD=your_secure_password
